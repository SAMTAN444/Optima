# Database — overridden by docker-compose; use localhost:5433 for local dev outside Docker
# (Docker Compose maps host port 5433 → container port 5432)
DATABASE_URL=postgresql://optima:optima@localhost:5433/optima

# Supabase — get from https://app.supabase.com -> Settings -> API
# Project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# OneMap — register at https://www.onemap.gov.sg/apidocs/
# Required for commute routing. App degrades gracefully without it.
#
# Option 1 (preferred): static token obtained from OneMap developer portal or API.
# Test with: GET /onemap/ping
ONEMAP_TOKEN=your-onemap-jwt-token

# Option 2 (legacy/deprecated): email + password are exchanged for a token at runtime.
# Only used when ONEMAP_TOKEN is NOT set. Ignored when ONEMAP_TOKEN is present.
# ONEMAP_EMAIL=your-onemap-email@example.com
# ONEMAP_PASSWORD=your-onemap-password

# Server
PORT=4000
NODE_ENV=development
